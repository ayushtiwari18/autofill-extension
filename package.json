{
  "name": "autofill-extension",
  "version": "0.1.0",
  "description": "Smart Job Application Autofill Chrome Extension",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "webpack --config webpack.config.cjs --mode production",
    "dev": "webpack --config webpack.config.cjs --mode development --watch",
    "clean": "rm -rf dist",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs --coverage",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs --watch",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.js"
  },
  "keywords": [
    "chrome-extension",
    "autofill",
    "job-application"
  ],
  "author": "Ayush Tiwari",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "@playwright/test": "^1.44.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.2",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "jest": "^29.7.0",
    "serve": "^14.2.0",
    "style-loader": "^3.3.3",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4"
  }
}
